<Window x:Class="aplikacje_desktopowe_zad4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:aplikacje_desktopowe_zad4"
        mc:Ignorable="d"
        Title="Kalkulator" Height="480" Width="360" ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="Black" BorderThickness="1" Margin="0,0,0,6" Padding="8">
            <TextBlock x:Name="DisplayText" Text="0" FontSize="32"
                       HorizontalAlignment="Right" TextWrapping="NoWrap"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Wiersz 1: reset, pierwiastek, odwrotnosc, silnia -->
            <Button Grid.Row="0" Grid.Column="0" Content="C" Click="Reset_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="√x" Click="Sqrt_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="1/x" Click="Invert_Click"/>
            <!-- Funkcja dodatkowa 1: silnia (n!) -->
            <Button Grid.Row="0" Grid.Column="3" Content="n!" Click="Factorial_Click"/>

            <!-- Wiersz 2: 7 8 9 dzielenie -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" Click="Digit_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" Click="Digit_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" Click="Digit_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="÷" Click="Operator_Click" Tag="/"/>

            <!-- Wiersz 3: 4 5 6 razy -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" Click="Digit_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" Click="Digit_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" Click="Digit_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="×" Click="Operator_Click" Tag="*"/>

            <!-- Wiersz 4: 1 2 3 minus -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" Click="Digit_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" Click="Digit_Click"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" Click="Digit_Click"/>
            <Button Grid.Row="3" Grid.Column="3" Content="-" Click="Operator_Click" Tag="-"/>

            <!-- Wiersz 5: 0 przecinek procent plus -->
            <Button Grid.Row="4" Grid.Column="0" Content="0" Click="Digit_Click"/>
            <Button Grid.Row="4" Grid.Column="1" Content="," Click="Decimal_Click"/>
            <Button Grid.Row="4" Grid.Column="2" Content="%" Click="Percent_Click"/>
            <Button Grid.Row="4" Grid.Column="3" Content="+" Click="Operator_Click" Tag="+"/>

            <!-- Wiersz 6: potega, mod, losowanie, rownosc -->
            <Button Grid.Row="5" Grid.Column="0" Content="x^y" Click="Operator_Click" Tag="^"/>
            <Button Grid.Row="5" Grid.Column="1" Content="mod" Click="Operator_Click" Tag="mod"/>
            <!-- Funkcja dodatkowa 2: losowanie liczby z przedzialu [0, x] -->
            <Button Grid.Row="5" Grid.Column="2" Content="rnd(0,x)" Click="Random_Click"/>
            <Button Grid.Row="5" Grid.Column="3" Content="=" Click="Equals_Click"/>
        </Grid>
    </Grid>
</Window>
