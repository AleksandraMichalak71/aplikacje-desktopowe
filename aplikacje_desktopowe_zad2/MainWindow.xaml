<Window x:Class="aplikacje_desktopowe_zad2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:aplikacje_desktopowe_zad2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        <!-- Styl 1: obramowanie 5px, margines, na hover/klik kolor tekstu
             staje sie zgodny z kolorem obramowania -->
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="DodgerBlue"/>
                    <Setter Property="Foreground" Value="DodgerBlue"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="BorderBrush" Value="Navy"/>
                    <Setter Property="Foreground" Value="Navy"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl domyslny (bez klucza) - dziedziczy po BaseButtonStyle, obowiazuje globalnie -->
        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}"/>

        <!-- Styl 3 - identyfikowany kluczem, jeszcze inny kolor tla -->
        <Style x:Key="AltButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="Khaki"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Gorna belka: styl 1 (domyslny) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="LightGray">
            <Button Content="Plik"/>
            <Button Content="Edycja"/>
            <Button Content="Widok"/>
        </StackPanel>

        <!-- Sub-siatka: lewa belka, dolna belka, przestrzen na zawartosc -->
        <Grid Grid.Row="1">
            <Grid.Resources>
                <!-- Styl 2 - zdefiniowany w sub-siatce, inny kolor tla -->
                <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                    <Setter Property="Background" Value="LightGreen"/>
                </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lewa belka: styl 2 (sub-siatki, zielone tlo) -->
            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Background="LightGray">
                <Button Content="Narzedzie 1"/>
                <Button Content="Narzedzie 2"/>
            </StackPanel>

            <!-- Przestrzen na zawartosc -->
            <Border Grid.Row="0" Grid.Column="1" BorderBrush="Black" BorderThickness="1"/>

            <!-- Dolna belka: styl 3 (alternatywny, po kluczu) -->
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Background="LightGray">
                <Button Content="OK" Style="{StaticResource AltButtonStyle}"/>
                <Button Content="Anuluj" Style="{StaticResource AltButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
